# Copy to .env and update values for your environment

# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1

# JWT — CHANGE THESE IN PRODUCTION (use openssl rand -hex 32)
JWT_SECRET=your_random_secret_at_least_32_characters_long
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_different_random_secret_at_least_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Database
# DB_CLIENT: "sqlite" for quick local dev, "pg" for PostgreSQL (production)
DB_CLIENT=sqlite
DB_PATH=./data/taskflow.db

# PostgreSQL (used when DB_CLIENT=pg)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskflow
DB_USER=taskflow_user
DB_PASSWORD=your_database_password

# Redis (optional — leave empty to disable)
REDIS_URL=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=dev
