# Copy to .env and update values
NODE_ENV=development
PORT=3000
API_VERSION=v1

# JWT — CHANGE THESE IN PRODUCTION
JWT_SECRET=your_random_secret_at_least_32_characters_long
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_different_random_secret_at_least_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Database
DB_PATH=./data/taskflow.db

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=dev
