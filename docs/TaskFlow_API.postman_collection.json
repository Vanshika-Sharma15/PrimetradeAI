{
  "info": {
    "name": "TaskFlow API",
    "description": "Production-ready REST API with JWT Authentication, RBAC & Task Management.\n\nSetup:\n1. Run the Register or Login request\n2. The access_token is automatically saved to the collection variable\n3. All protected endpoints use it via Bearer auth\n\nDemo credentials:\n- Admin: admin@taskflow.io / Admin@123\n- User: user@taskflow.io / User@123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "taskflow"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "taskId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Healthy', () => pm.expect(pm.response.json().data.status).to.eql('healthy'));"
              ]
            }
          }]
        },
        {
          "name": "API Info",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/api",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"username\": \"newuser\",\n  \"password\": \"MyPass@123\",\n  \"first_name\": \"New\",\n  \"last_name\": \"User\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "const data = pm.response.json().data;",
                "if (data) {",
                "  pm.collectionVariables.set('accessToken', data.access_token);",
                "  pm.collectionVariables.set('refreshToken', data.refresh_token);",
                "  pm.collectionVariables.set('userId', data.user.id);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@taskflow.io\",\n  \"password\": \"Admin@123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const data = pm.response.json().data;",
                "if (data) {",
                "  pm.collectionVariables.set('accessToken', data.access_token);",
                "  pm.collectionVariables.set('refreshToken', data.refresh_token);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Login (User)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@taskflow.io\",\n  \"password\": \"User@123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const data = pm.response.json().data;",
                "if (data) {",
                "  pm.collectionVariables.set('accessToken', data.access_token);",
                "  pm.collectionVariables.set('refreshToken', data.refresh_token);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const data = pm.response.json().data;",
                "if (data) {",
                "  pm.collectionVariables.set('accessToken', data.access_token);",
                "  pm.collectionVariables.set('refreshToken', data.refresh_token);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/profile"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has email', () => pm.expect(pm.response.json().data.email).to.be.a('string'));"
              ]
            }
          }]
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/auth/profile",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Updated\",\n  \"last_name\": \"Name\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/change-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"User@123\",\n  \"new_password\": \"NewPass@456\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "todo", "disabled": true },
                { "key": "priority", "value": "high", "disabled": true },
                { "key": "search", "value": "", "disabled": true },
                { "key": "sort", "value": "created_at", "disabled": true },
                { "key": "order", "value": "desc", "disabled": true }
              ]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has pagination', () => pm.expect(pm.response.json().pagination).to.be.an('object'));",
                "pm.test('Data is array', () => pm.expect(pm.response.json().data).to.be.an('array'));"
              ]
            }
          }]
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tasks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Implement user notifications\",\n  \"description\": \"Add email and push notification support for task assignments\",\n  \"status\": \"todo\",\n  \"priority\": \"high\",\n  \"due_date\": \"2026-05-01T00:00:00.000Z\",\n  \"tags\": [\"backend\", \"notifications\"]\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "const data = pm.response.json().data;",
                "if (data) pm.collectionVariables.set('taskId', data.id);"
              ]
            }
          }]
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks/{{taskId}}"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Correct task', () => pm.expect(pm.response.json().data.id).to.eql(pm.collectionVariables.get('taskId')));"
              ]
            }
          }]
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/tasks/{{taskId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\",\n  \"priority\": \"critical\",\n  \"tags\": [\"backend\", \"notifications\", \"urgent\"]\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Status updated', () => pm.expect(pm.response.json().data.status).to.eql('in_progress'));"
              ]
            }
          }]
        },
        {
          "name": "Get Task Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks/stats"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has total', () => pm.expect(pm.response.json().data.total).to.be.a('number'));"
              ]
            }
          }]
        },
        {
          "name": "Filter Tasks (status=todo)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks?status=todo"
          }
        },
        {
          "name": "Filter Tasks (priority=high)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks?priority=high"
          }
        },
        {
          "name": "Search Tasks",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks?search=notification"
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/tasks/{{taskId}}"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "Admin",
      "description": "Requires admin role. Login with admin@taskflow.io first.",
      "item": [
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/users?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "role", "value": "user", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has users', () => pm.expect(pm.response.json().data.length).to.be.above(0));"
              ]
            }
          }]
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/users/{{userId}}"
          }
        },
        {
          "name": "Update User Role",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/admin/users/{{userId}}/role",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Toggle User Active/Inactive",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/admin/users/{{userId}}/toggle-active"
          }
        },
        {
          "name": "View Audit Logs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/audit-logs?page=1&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "audit-logs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "50" },
                { "key": "action", "value": "LOGIN", "disabled": true },
                { "key": "entity_type", "value": "user", "disabled": true }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Error Cases",
      "description": "Requests that test error handling",
      "item": [
        {
          "name": "Login — Wrong Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@taskflow.io\",\n  \"password\": \"wrongpassword\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"] }
          }]
        },
        {
          "name": "Register — Validation Error",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"notanemail\",\n  \"username\": \"ab\",\n  \"password\": \"weak\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 400', () => pm.response.to.have.status(400));",
                "pm.test('Has errors', () => pm.expect(pm.response.json().errors).to.be.an('array'));"
              ]
            }
          }]
        },
        {
          "name": "Access Admin Without Auth",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/users",
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"] }
          }]
        },
        {
          "name": "Not Found Route",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/nonexistent",
            "auth": { "type": "noauth" }
          },
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 404', () => pm.response.to.have.status(404));"] }
          }]
        }
      ]
    }
  ]
}
