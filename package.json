    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "sql.js": "^1.14.1",
    "swagger-jsdoc": "^6.2.8",
